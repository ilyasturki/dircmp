{
    "name": "dircmp",
    "version": "0.4.1",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.tsx",
        "dev:watch": "tsx --watch src/index.tsx",
        "format": "prettier --write '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
        "format:check": "prettier --check '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
        "build": "bun build src/index.tsx --compile --outfile dircmp",
        "typecheck": "tsc --noEmit",
        "version": "./scripts/update-nix-hash.sh && git add flake.nix CHANGELOG.md"
    },
    "dependencies": {
        "diff": "^8.0.3",
        "ignore": "^7.0.5",
        "ink": "^6.8.0",
        "ink-text-input": "^6.0.0",
        "meow": "^14.1.0",
        "os-theme": "^0.0.8",
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/node": "^25.3.4",
        "@types/react": "^19.2.14",
        "prettier": "^3.8.1",
        "react-devtools-core": "^7.0.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
