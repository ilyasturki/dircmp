{
  "name": "dirdiff",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:watch": "tsx --watch src/index.tsx",
    "format": "prettier --write '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
    "format:check": "prettier --check '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mishieck/ink-titled-box": "^0.4.2",
    "diff": "^8.0.3",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "@types/node": "^25.3.4"
  }
}
