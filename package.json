{
    "name": "dircmp",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.tsx",
        "dev:watch": "tsx --watch src/index.tsx",
        "format": "prettier --write '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
        "format:check": "prettier --check '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "diff": "^8.0.3",
        "ink": "^6.8.0",
        "ink-text-input": "^6.0.0",
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/node": "^25.3.4",
        "@types/react": "^19.2.14",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
