{
    "name": "@ilyasturki/dircmp",
    "version": "1.5.0",
    "type": "module",
    "description": "Side-by-side directory and file diff for your terminal",
    "author": "Ilyas Turki",
    "license": "MIT",
    "homepage": "https://github.com/ilyasturki/dircmp#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ilyasturki/dircmp.git"
    },
    "bugs": "https://github.com/ilyasturki/dircmp/issues",
    "keywords": [
        "cli",
        "tui",
        "terminal",
        "diff",
        "directory",
        "compare",
        "file-manager",
        "ink"
    ],
    "bin": {
        "dircmp": "bin/dircmp.js"
    },
    "files": [
        "bin",
        "dist",
        "CHANGELOG.md"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "XDG_CONFIG_HOME=./.dev/config XDG_DATA_HOME=./.dev/data tsx src/index.tsx",
        "dev:watch": "XDG_CONFIG_HOME=./.dev/config XDG_DATA_HOME=./.dev/data tsx --watch src/index.tsx",
        "dev:prod": "XDG_CONFIG_HOME=./.prod/config XDG_DATA_HOME=./.prod/data tsx src/index.tsx",
        "format": "prettier --write '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
        "format:check": "prettier --check '**/*.{js,ts,jsx,tsx,vue,css,scss,html,json,md,yml}'",
        "build": "bun scripts/build-binary.ts --outfile dircmp",
        "build:npm": "bun build src/index.tsx --outfile dist/index.js --target=node --define process.env.DEV='\"false\"'",
        "prepublishOnly": "bun run build:npm",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "version": "./scripts/update-nix-hash.sh && git add flake.nix CHANGELOG.md README.md"
    },
    "dependencies": {
        "diff": "^9.0.0",
        "ignore": "^7.0.5",
        "ink": "^7.0.0",
        "meow": "^14.1.0",
        "react": "^19.2.5"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/bun": "^1.3.12",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "prettier": "^3.8.2",
        "react-devtools-core": "^7.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
